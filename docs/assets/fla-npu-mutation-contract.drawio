<mxfile host="Electron" modified="2026-07-15T06:30:00.000Z" agent="Codex" version="24.7.17">
  <diagram id="mutation-contract" name="状态修改契约">
    <mxGraphModel dx="1500" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="&lt;b&gt;ctypes 直接修改 cache：wrapper 必须补齐 PyTorch 语义&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=25;fontColor=#172033;" vertex="1" parent="1"><mxGeometry x="160" y="25" width="1180" height="45" as="geometry"/></mxCell>
        <mxCell id="subtitle" value="stream 保证真实执行顺序；alias / mutation schema 保证 autograd 和编译器理解副作用" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=15;fontColor=#52606D;" vertex="1" parent="1"><mxGeometry x="230" y="72" width="1040" height="30" as="geometry"/></mxCell>

        <mxCell id="native" value="&lt;b&gt;1  aclnn / ctypes 实际行为&lt;/b&gt;&lt;br/&gt;kernel 通过 data pointer 读取并改写 conv_states storage&lt;br/&gt;输出 y 是新 tensor；cache 修改发生在 current NPU stream" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#EEF4FF;strokeColor=#5B7DB1;strokeWidth=2;fontSize=15;fontColor=#172033;spacing=8;" vertex="1" parent="1"><mxGeometry x="240" y="125" width="1020" height="95" as="geometry"/></mxCell>
        <mxCell id="gap" value="&lt;b&gt;2  raw ctypes 的语义缺口&lt;/b&gt;&lt;br/&gt;PyTorch 只看到 Python 返回了 y，看不到 conv_states 已被修改&lt;br/&gt;不会自动推进版本计数，也没有 dispatcher alias / mutation schema" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#FFF1F1;strokeColor=#D85C5C;strokeWidth=2.5;fontSize=15;fontColor=#6F2424;spacing=8;" vertex="1" parent="1"><mxGeometry x="425" y="265" width="650" height="100" as="geometry"/></mxCell>

        <mxCell id="eager" value="&lt;b&gt;A  Eager mutable&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;• 声明 mutated args&lt;br/&gt;• launch 后推进 tensor version&lt;br/&gt;• cache/state 限制为 no-grad&lt;br/&gt;• 未适配时显式 graph break&lt;br/&gt;&lt;br/&gt;&lt;b&gt;结论：适合 eager 推理&lt;/b&gt;" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#FFF7E8;strokeColor=#D9970B;strokeWidth=2;fontSize=15;fontColor=#5D4200;spacing=10;align=left;" vertex="1" parent="1"><mxGeometry x="45" y="455" width="430" height="245" as="geometry"/></mxCell>
        <mxCell id="compiler" value="&lt;b&gt;B  Compiler-visible mutable&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;• Python torch.library.custom_op&lt;br/&gt;• mutates_args={conv_states}&lt;br/&gt;• 新输出 y 的 FakeTensor 规则&lt;br/&gt;• opcheck + eager/compile 对比&lt;br/&gt;&lt;br/&gt;&lt;b&gt;结论：可支持图编译&lt;/b&gt;" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#EFF9F1;strokeColor=#4C9B60;strokeWidth=2;fontSize=15;fontColor=#244B2F;spacing=10;align=left;" vertex="1" parent="1"><mxGeometry x="535" y="455" width="430" height="245" as="geometry"/></mxCell>
        <mxCell id="functional" value="&lt;b&gt;C  Functional state&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;• 不修改输入 cache&lt;br/&gt;• 显式返回 (y, new_state)&lt;br/&gt;• 新状态不与旧状态 alias&lt;br/&gt;• 单独定义 autograd / FakeTensor&lt;br/&gt;&lt;br/&gt;&lt;b&gt;结论：训练与导出的首选&lt;/b&gt;" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#F4F0FF;strokeColor=#8266B5;strokeWidth=2;fontSize=15;fontColor=#49366B;spacing=10;align=left;" vertex="1" parent="1"><mxGeometry x="1025" y="455" width="430" height="245" as="geometry"/></mxCell>

        <mxCell id="note" value="&lt;b&gt;两类正确性不能互相替代&lt;/b&gt;&lt;br/&gt;current stream / event 解决设备侧先后关系；版本计数、mutates_args 和 FakeTensor 解决 PyTorch 侧的状态、autograd 与图变换语义。" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#EEF6FF;strokeColor=#3973B7;strokeWidth=2.5;fontSize=16;fontColor=#1F466F;spacing=10;" vertex="1" parent="1"><mxGeometry x="180" y="770" width="1140" height="90" as="geometry"/></mxCell>

        <mxCell id="e-native-gap" value="实际写入" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2.4;strokeColor=#D85C5C;fontSize=13;fontColor=#7A2929;labelBackgroundColor=#FFFFFF;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="native" target="gap"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e-gap-eager" value="仅 eager" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2.4;strokeColor=#D9970B;fontSize=13;fontColor=#6A4A00;labelBackgroundColor=#FFFFFF;exitX=0.2;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="gap" target="eager"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="555" y="410"/><mxPoint x="260" y="410"/></Array></mxGeometry></mxCell>
        <mxCell id="e-gap-compiler" value="需要入图" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2.4;strokeColor=#4C9B60;fontSize=13;fontColor=#244B2F;labelBackgroundColor=#FFFFFF;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="gap" target="compiler"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e-gap-functional" value="显式状态流" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2.4;strokeColor=#8266B5;fontSize=13;fontColor=#49366B;labelBackgroundColor=#FFFFFF;exitX=0.8;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="gap" target="functional"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="945" y="410"/><mxPoint x="1240" y="410"/></Array></mxGeometry></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
