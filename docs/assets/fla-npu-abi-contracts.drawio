<mxfile host="Electron" modified="2026-07-15T03:20:00.000Z" agent="Codex" version="24.7.17">
  <diagram id="abi-contracts" name="底层 ABI 契约">
    <mxGraphModel dx="1500" dy="1040" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1040" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="&lt;b&gt;PyTorch / torch_npu 解耦需要稳定的接口与跨版本策略&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=25;fontColor=#172033;" vertex="1" parent="1"><mxGeometry x="180" y="25" width="1140" height="45" as="geometry"/></mxCell>
        <mxCell id="subtitle" value="tensor / storage、backend / stream、autograd 和必要 C 符号采用分层能力契约" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=15;fontColor=#52606D;" vertex="1" parent="1"><mxGeometry x="250" y="72" width="1000" height="30" as="geometry"/></mxCell>
        <mxCell id="left-header" value="&lt;b&gt;稳定接口 / ABI 契约&lt;/b&gt;" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#EEF4FF;strokeColor=#5B7DB1;strokeWidth=2;fontSize=19;fontColor=#24466F;" vertex="1" parent="1"><mxGeometry x="40" y="120" width="900" height="55" as="geometry"/></mxCell>
        <mxCell id="right-header" value="&lt;b&gt;跨版本不一致时的策略&lt;/b&gt;" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#F4F0FF;strokeColor=#8266B5;strokeWidth=2;fontSize=19;fontColor=#49366B;" vertex="1" parent="1"><mxGeometry x="1030" y="120" width="430" height="55" as="geometry"/></mxCell>

        <mxCell id="c1" value="&lt;b&gt;1  torch tensor / storage Python 能力契约&lt;/b&gt;&lt;br/&gt;device、dtype、shape、stride、storage、data_ptr、storage_offset&lt;br/&gt;输出分配和 storage 生命周期语义" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#EFF9F1;strokeColor=#4C9B60;strokeWidth=2;fontSize=14;fontColor=#172033;spacing=7;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="195" width="900" height="80" as="geometry"/></mxCell>
        <mxCell id="s1" value="&lt;b&gt;能力探测 + Python adapter&lt;/b&gt;&lt;br/&gt;保留 untyped_storage / storage fallback&lt;br/&gt;不按 torch patch 锁版本" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#EFF9F1;strokeColor=#4C9B60;strokeWidth=2;fontSize=13;fontColor=#244B2F;spacing=7;" vertex="1" parent="1"><mxGeometry x="1030" y="195" width="430" height="80" as="geometry"/></mxCell>

        <mxCell id="c2" value="&lt;b&gt;2  torch_npu backend / stream 能力契约&lt;/b&gt;&lt;br/&gt;NPU device 注册、NPU tensor 可执行性、torch.npu.current_stream()&lt;br/&gt;npu_stream 指针与外部 executor 的当前 stream 语义" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#EEF4FF;strokeColor=#5B7DB1;strokeWidth=2;fontSize=14;fontColor=#172033;spacing=7;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="305" width="900" height="80" as="geometry"/></mxCell>
        <mxCell id="s2" value="&lt;b&gt;backend smoke + stream provider&lt;/b&gt;&lt;br/&gt;功能探针确认 torch / torch_npu 配套&lt;br/&gt;不把 torch_npu 变成默认 import 依赖" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#EEF4FF;strokeColor=#5B7DB1;strokeWidth=2;fontSize=13;fontColor=#24466F;spacing=7;" vertex="1" parent="1"><mxGeometry x="1030" y="305" width="430" height="80" as="geometry"/></mxCell>

        <mxCell id="c3" value="&lt;b&gt;3  ACL descriptor / runtime C ABI&lt;/b&gt;&lt;br/&gt;aclCreateTensor / aclDestroyTensor / aclCreateIntArray / aclDestroyIntArray&lt;br/&gt;aclTensor、aclIntArray、aclOpExecutor、aclrtStream 保持 opaque 语义" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#FFF7E8;strokeColor=#D9970B;strokeWidth=2;fontSize=14;fontColor=#172033;spacing=7;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="415" width="900" height="80" as="geometry"/></mxCell>
        <mxCell id="s3" value="&lt;b&gt;符号 preflight + runtime adapter&lt;/b&gt;&lt;br/&gt;解析必要符号并保持 opaque 生命周期&lt;br/&gt;该层接口稳定，保留符号检查即可" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#FFF7E8;strokeColor=#D9970B;strokeWidth=2;fontSize=13;fontColor=#6A4A00;spacing=7;" vertex="1" parent="1"><mxGeometry x="1030" y="415" width="430" height="80" as="geometry"/></mxCell>

        <mxCell id="c4" value="&lt;b&gt;4  每算子 aclnn C ABI&lt;/b&gt;&lt;br/&gt;aclnnXxxGetWorkspaceSize 的参数顺序、C 类型、optional 语义和输出数量&lt;br/&gt;aclnnXxx(workspace, size, executor, stream) 两段式 launch" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#F4F0FF;strokeColor=#8266B5;strokeWidth=2;fontSize=14;fontColor=#172033;spacing=7;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="525" width="900" height="80" as="geometry"/></mxCell>
        <mxCell id="s4" value="&lt;b&gt;旧符号签名冻结&lt;/b&gt;&lt;br/&gt;不兼容修改发布新符号 / V2&lt;br/&gt;wrapper 按符号选择；header hash 进 CI" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#F4F0FF;strokeColor=#8266B5;strokeWidth=2;fontSize=13;fontColor=#49366B;spacing=7;" vertex="1" parent="1"><mxGeometry x="1030" y="525" width="430" height="80" as="geometry"/></mxCell>

        <mxCell id="c5" value="&lt;b&gt;5  PyTorch autograd Python 契约&lt;/b&gt;&lt;br/&gt;torch.autograd.Function、save_for_backward、forward/backward 参数数量&lt;br/&gt;optional tensor、梯度返回和上下文生命周期" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#FFF1F1;strokeColor=#D85C5C;strokeWidth=2;fontSize=14;fontColor=#172033;spacing=7;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="635" width="900" height="80" as="geometry"/></mxCell>
        <mxCell id="s5" value="&lt;b&gt;Python 正反向 adapter + 梯度测试&lt;/b&gt;&lt;br/&gt;绑定集中在公共入口&lt;br/&gt;不使用 torch_npu derivatives / dispatcher autograd" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#FFF1F1;strokeColor=#D85C5C;strokeWidth=2;fontSize=13;fontColor=#7A2929;spacing=7;" vertex="1" parent="1"><mxGeometry x="1030" y="635" width="430" height="80" as="geometry"/></mxCell>

        <mxCell id="c6" value="&lt;b&gt;6  OPP 符号加载契约&lt;/b&gt;&lt;br/&gt;vendor / 算子名、libcust_opapi.so、必需 aclnn 符号&lt;br/&gt;OPP 搜索优先级和当前进程动态库缓存" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#EEF8F8;strokeColor=#3F8C8C;strokeWidth=2;fontSize=14;fontColor=#172033;spacing=7;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="745" width="900" height="80" as="geometry"/></mxCell>
        <mxCell id="s6" value="&lt;b&gt;同包交付 + 符号检查&lt;/b&gt;&lt;br/&gt;run 覆盖同步更新算子清单&lt;br/&gt;覆盖后重启 Python，避免复用旧 CDLL / 符号" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#EEF8F8;strokeColor=#3F8C8C;strokeWidth=2;fontSize=13;fontColor=#285F5F;spacing=7;" vertex="1" parent="1"><mxGeometry x="1030" y="745" width="430" height="80" as="geometry"/></mxCell>

        <mxCell id="c7" value="&lt;b&gt;7  Triton Python / JIT 能力契约（独立于 Ascend C OPP）&lt;/b&gt;&lt;br/&gt;triton / triton.language API、NPU backend driver、目标设备能力&lt;br/&gt;kernel 在目标环境 JIT，不复用 libcust_opapi.so ABI" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#F7F3FF;strokeColor=#9A74C8;strokeWidth=2;fontSize=14;fontColor=#172033;spacing=7;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="855" width="900" height="80" as="geometry"/></mxCell>
        <mxCell id="s7" value="&lt;b&gt;版本下限 + capability probe&lt;/b&gt;&lt;br/&gt;在目标设备 JIT / smoke test&lt;br/&gt;Triton 失败不改变 Ascend C ABI 判定" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#F7F3FF;strokeColor=#9A74C8;strokeWidth=2;fontSize=13;fontColor=#5E3D82;spacing=7;" vertex="1" parent="1"><mxGeometry x="1030" y="855" width="430" height="80" as="geometry"/></mxCell>

        <mxCell id="note" value="&lt;b&gt;原则：Python 能力变化用 adapter；torch / torch_npu 配套性用功能探针和测试矩阵；同名 C ABI 不兼容必须版本化。&lt;/b&gt;" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#E9F7EE;strokeColor=#4C9B60;strokeWidth=2;fontSize=15;fontColor=#244B2F;" vertex="1" parent="1"><mxGeometry x="180" y="965" width="1140" height="50" as="geometry"/></mxCell>

        <mxCell id="e1" value="" style="edgeStyle=none;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2.2;strokeColor=#4C9B60;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="c1" target="s1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" value="" style="edgeStyle=none;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2.2;strokeColor=#5B7DB1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="c2" target="s2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" value="" style="edgeStyle=none;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2.2;strokeColor=#D9970B;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="c3" target="s3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" value="" style="edgeStyle=none;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2.2;strokeColor=#8266B5;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="c4" target="s4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" value="" style="edgeStyle=none;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2.2;strokeColor=#D85C5C;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="c5" target="s5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" value="" style="edgeStyle=none;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2.2;strokeColor=#3F8C8C;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="c6" target="s6"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" value="" style="edgeStyle=none;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2.2;strokeColor=#9A74C8;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="c7" target="s7"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
